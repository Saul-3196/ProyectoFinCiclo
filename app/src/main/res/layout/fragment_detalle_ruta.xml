<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="30dp">

        <FrameLayout
            android:id="@+id/containerHeader"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivDetalleFoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/fotoruta" />

            <TextView
                android:id="@+id/tvVolverDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:text="← Volver"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:shadowColor="@android:color/black"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </FrameLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-30dp"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/containerHeader">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvDetalleTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:text="Título de la Ruta" />

                <TextView
                    android:id="@+id/tvDetalleCreador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:text="Por: Usuario" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#EEEEEE" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2">

                    <TextView android:id="@+id/tvDetalleKm" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_marginBottom="12dp" android:text="📏 -- km" />
                    <TextView android:id="@+id/tvDetalleDificultad" android:layout_width="0dp" android:layout_columnWeight="1" android:text="📊 Dificultad" />
                    <TextView android:id="@+id/tvDetalleTipo" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_marginBottom="12dp" android:text="🚴 Tipo" />
                    <TextView android:id="@+id/tvDetalleLocalidad" android:layout_width="0dp" android:layout_columnWeight="1" android:text="📍 Localidad" />
                    <TextView android:id="@+id/tvDetalleFecha" android:layout_width="0dp" android:layout_columnWeight="1" android:text="📅 Fecha" />
                    <TextView android:id="@+id/tvDetalleHora" android:layout_width="0dp" android:layout_columnWeight="1" android:text="⏰ Hora" />
                </GridLayout>

                <TextView
                    android:id="@+id/tvDetalleDesnivel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛰️ Desnivel: 0 m"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvDetallePunto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textStyle="italic"
                    android:text="🫂 Punto encuentro:" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Descripción de la ruta"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <TextView
                    android:id="@+id/tvDetalleDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#424242" />

                <TextView
                    android:id="@+id/tvListaParticipantes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="12dp"
                    android:background="#E3F2FD"
                    android:text="👥 Sé el primero en unirte"
                    android:textColor="#1976D2"
                    android:textSize="15sp"
                    android:textStyle="bold|italic" />

                <fragment
                    android:id="@+id/mapa_detalle"
                    android:name="com.example.proyectofinciclo.ui.CustomSupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="16dp"
                    app:uiZoomControls="true"
                    app:uiScrollGestures="true">
                </fragment>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnirseRuta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Unirse a esta ruta"
                    android:padding="16dp"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#FF9800"
                    android:textColor="@android:color/white"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>